<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.view.SistemaController">

    <!-- TOPO -->
    <top>
        <VBox>
            <MenuBar>
                <menus>
                    <Menu text="Inicio">
                        <items>
                            <MenuItem fx:id="itemSair" onAction="#Sair" text="Sair" />
                        </items>
                    </Menu>

                    <Menu text="Cadastros">
                        <items>
                            <MenuItem fx:id="itemProdutos" onAction="#AbrirCadastroProduto" text="Produtos" />
                            <MenuItem fx:id="itemUsuario" onAction="#AbrirCadastroUsuarios" text="Usuários" />
                            <MenuItem fx:id="itemCliente" onAction="#AbrirCadastroClientes" text="Clientes" />
                        </items>
                    </Menu>

                    <Menu text="Operações">
                        <items>
                            <MenuItem fx:id="itemProcessaEstoque" onAction="#AbrirProcessaEstoque" text="Processar Estoque" />
                        </items>
                    </Menu>
                </menus>
            </MenuBar>

            <!-- TÍTULO -->
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 10 0 10 10;" text="Sistema de Vendas e Estoque" />
        </VBox>
    </top>

    <!-- CENTRO -->
    <center>
        <VBox alignment="CENTER" spacing="20">

            <Label style="-fx-font-size: 18px;" text="Bem-vindo ao sistema" />
   
            <!-- BOTÕES RÁPIDOS -->
            <HBox alignment="CENTER" spacing="20">
   
                <Button onAction="#AbrirCadastroClientes" prefHeight="40" prefWidth="120" text="Clientes" />
   
                <Button onAction="#AbrirCadastroProduto" prefHeight="40" prefWidth="120" text="Produtos" />
   
                <Button onAction="#AbrirProcessaEstoque" prefHeight="40" prefWidth="120" text="Estoque" />
            <Button layoutX="350.0" layoutY="10.0" onAction="#AbrirPDV" prefHeight="40" prefWidth="120" text="Vendas" />
   
            </HBox>

        </VBox>
    </center>

</BorderPane>
