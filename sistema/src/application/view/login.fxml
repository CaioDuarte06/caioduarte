<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="470.0" prefWidth="318.0"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="application.view.LoginController">

    <children>

        <!-- FUNDO -->
        <AnchorPane style="-fx-background-color: linear-gradient(to bottom, #2c7be5, #1a4fa0);" />

        <!-- CARD -->
        <VBox alignment="CENTER" spacing="15"
              maxWidth="250"
              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">

            <!-- TÍTULO -->
            <Label text="Tela de Login">
                <font>
                    <Font name="System Bold" size="16.0" />
                </font>
            </Label>

            <!-- USUÁRIO -->
            <TextField fx:id="txtUsuario"
                       promptText="Usuário"
                       prefHeight="35"
                       style="-fx-border-radius: 5;" />

            <!-- SENHA -->
            <PasswordField fx:id="txtSenha"
                           promptText="Senha"
                           prefHeight="35"
                           style="-fx-border-radius: 5;" />

            <!-- BOTÃO -->
            <Button fx:id="btnEntrar"
                    text="Entrar"
                    onAction="#entrar"
                    defaultButton="true"
                    prefWidth="180" prefHeight="35"
                    style="-fx-background-color: #2c7be5; -fx-text-fill: white;" />

        </VBox>

    </children>
</StackPane>